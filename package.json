{
  "name": "session-bridge",
  "displayName": "Session Bridge",
  "description": "Unofficial VSCode extension for managing Entire sessions, checkpoints, and recovery workflows",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "session-bridge",
          "title": "Session Bridge for Entire",
          "icon": "media/logo.svg"
        }
      ]
    },
    "views": {
      "session-bridge": [
        {
          "id": "session.bridge.entire.workspace",
          "name": "Workspace",
          "icon": "media/logo.png"
        },
        {
          "id": "session.bridge.entire.activeSessions",
          "name": "Active Sessions",
          "icon": "media/dark/play.svg"
        },
        {
          "id": "session.bridge.entire.checkpoints",
          "name": "Checkpoints",
          "icon": "media/dark/history.svg"
        },
        {
          "id": "session.bridge.entire.recovery",
          "name": "Recovery",
          "icon": "media/dark/wrench.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "session.bridge.entire.workspace",
        "when": "gitOpenRepositoryCount == 0",
        "contents": "Open a Git repository to inspect Entire workspace state.\n[Open Folder](command:vscode.openFolder)"
      },
      {
        "view": "session.bridge.entire.workspace",
        "when": "gitOpenRepositoryCount != 0 && session.bridge.state.cli-missing",
        "contents": "The Entire CLI is not available in the extension host environment.\n[Refresh workspace state](command:session.bridge.entire.refresh) \n[Read the Entire documentation](https://docs.entire.io)"
      },
      {
        "view": "session.bridge.entire.workspace",
        "when": "gitOpenRepositoryCount != 0 && session.bridge.state.not-git-repo",
        "contents": "Entire features require a Git repository.\n[Open Folder](command:vscode.openFolder)"
      },
      {
        "view": "session.bridge.entire.workspace",
        "when": "gitOpenRepositoryCount != 0 && session.bridge.state.disabled",
        "contents": "Entire is not enabled for this repository.\n[Fetch checkpoint branch](command:session.bridge.entire.fetchCheckpointBranch)\n[Refresh workspace state](command:session.bridge.entire.refresh)"
      },
      {
        "view": "session.bridge.entire.workspace",
        "when": "gitOpenRepositoryCount != 0 && session.bridge.state.enabled",
        "contents": "Entire is enabled for this repository.\n[Browse Checkpoints](command:session.bridge.entire.browseCheckpoints)\n[Refresh workspace state](command:session.bridge.entire.refresh)\n[Read the Entire documentation](https://docs.entire.io)"
      },
      {
        "view": "session.bridge.entire.activeSessions",
        "when": "session.bridge.state.not-git-repo",
        "contents": "Open a Git repository to see active sessions."
      },
      {
        "view": "session.bridge.entire.activeSessions",
        "when": "session.bridge.state.cli-missing",
        "contents": "Sessions will appear here after Entire cli is installed and Enabled."
      },
      {
        "view": "session.bridge.entire.activeSessions",
        "when": "session.bridge.state.disabled",
        "contents": "Entire Sessions will appear here after Entire is Enabled."
      },
      {
        "view": "session.bridge.entire.activeSessions",
        "when": "session.bridge.state.enabled",
        "contents": "No active sessions.\n[Refresh session state](command:session.bridge.entire.refresh)"
      },
      {
        "view": "session.bridge.entire.checkpoints",
        "when": "session.bridge.state.not-git-repo",
        "contents": "Open a Git repository to see checkpoints."
      },
      {
        "view": "session.bridge.entire.checkpoints",
        "when": "session.bridge.state.cli-missing",
        "contents": "Entire checkpoints will appear here after Entire cli is installed and Enabled."
      },
      {
        "view": "session.bridge.entire.checkpoints",
        "when": "session.bridge.state.disabled",
        "contents": "Entire checkpoints will appear here after Entire is enabled" 
      },
      {
        "view": "session.bridge.entire.checkpoints",
        "when": "session.bridge.state.enabled",
        "contents": "No checkpoints on this branch.\n[Refresh checkpoint state](command:session.bridge.entire.refresh)"
      },
      {
        "view": "session.bridge.entire.recovery",
        "when": "gitOpenRepositoryCount == 0",
        "contents": "Recovery actions become available after you open a Git repository."
      },
      {
        "view": "session.bridge.entire.recovery",
        "when": "gitOpenRepositoryCount != 0 && session.bridge.state.cli-missing",
        "contents": "Recovery actions become available after Entire is enabled."
      },
      {
        "view": "session.bridge.entire.recovery",
        "when": "gitOpenRepositoryCount != 0 && session.bridge.state.enabled",
        "contents": "Recovery actions stay explicit in this view.\n[Run Doctor](command:session.bridge.entire.runDoctor)\n[Resume Branch Session](command:session.bridge.entire.resumeBranch)\n[Clean Entire State](command:session.bridge.entire.clean)\n[Reset Entire Session Data](command:session.bridge.entire.reset)\n[Show Trace](command:session.bridge.entire.showTrace)"
      },
      {
        "view": "session.bridge.entire.recovery",
        "when": "gitOpenRepositoryCount != 0 && session.bridge.state.disabled",
        "contents": "Recovery actions become available after Entire is enabled."
      }
    ],
    "commands": [
      {
        "command": "session.bridge.entire.showStatus",
        "title": "Show Status",
        "category": "Session Bridge (Entire)"
      },
      {
        "command": "session.bridge.entire.enable",
        "title": "Enable In Repository",
        "category": "Session Bridge (Entire)"
      },
      {
        "command": "session.bridge.entire.disable",
        "title": "Disable In Repository",
        "category": "Session Bridge (Entire)"
      },
      {
        "command": "session.bridge.entire.refresh",
        "title": "Refresh",
        "category": "Session Bridge (Entire)"
      },
      {
        "command": "session.bridge.entire.fetchCheckpointBranch",
        "title": "Fetch Checkpoint Branch",
        "category": "Session Bridge (Entire)"
      },
      {
        "command": "session.bridge.entire.browseCheckpoints",
        "title": "Browse Checkpoints",
        "category": "Session Bridge (Entire)"
      },
      {
        "command": "session.bridge.entire.explainCheckpoint",
        "title": "Explain Checkpoint",
        "category": "Session Bridge (Entire)"
      },
      {
        "command": "session.bridge.entire.explainCommit",
        "title": "Explain Commit",
        "category": "Session Bridge (Entire)"
      },
      {
        "command": "session.bridge.entire.openRawTranscript",
        "title": "Open Raw Transcript",
        "category": "Session Bridge (Entire)"
      },
      {
        "command": "session.bridge.entire.rewindInteractive",
        "title": "Rewind To Checkpoint",
        "category": "Session Bridge (Entire)"
      },
      {
        "command": "session.bridge.entire.resumeBranch",
        "title": "Resume Branch Session",
        "category": "Session Bridge (Entire)"
      },
      {
        "command": "session.bridge.entire.runDoctor",
        "title": "Run Doctor",
        "category": "Session Bridge (Entire)"
      },
      {
        "command": "session.bridge.entire.clean",
        "title": "Clean Entire State",
        "category": "Session Bridge (Entire)"
      },
      {
        "command": "session.bridge.entire.reset",
        "title": "Reset Entire Session Data",
        "category": "Session Bridge (Entire)"
      },
      {
        "command": "session.bridge.entire.showTrace",
        "title": "Show Trace",
        "category": "Session Bridge (Entire)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "session.bridge.entire.refresh",
          "when": "view =~ /^session\\.bridge\\.entire\\./",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
