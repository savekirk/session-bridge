{
  "name": "session-bridge",
  "displayName": "Session Bridge",
  "description": "Unofficial VSCode extension for managing Entire sessions, checkpoints, and recovery workflows",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "entire",
          "title": "Entire",
          "icon": "media/logo.svg"
        }
      ]
    },
    "views": {
      "entire": [
        {
          "id": "entire.workspace",
          "name": "Workspace",
          "icon": "media/logo.png"
        },
        {
          "id": "entire.activeSessions",
          "name": "Active Sessions",
          "icon": "media/dark/play.svg"
        },
        {
          "id": "entire.checkpoints",
          "name": "Checkpoints",
          "icon": "media/dark/history.svg"
        },
        {
          "id": "entire.recovery",
          "name": "Recovery",
          "icon": "media/dark/wrench.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "entire.showStatus",
        "title": "Show Status",
        "category": "Entire"
      },
      {
        "command": "entire.enable",
        "title": "Enable In Repository",
        "category": "Entire"
      },
      {
        "command": "entire.disable",
        "title": "Disable In Repository",
        "category": "Entire"
      },
      {
        "command": "entire.refresh",
        "title": "Refresh",
        "category": "Entire"
      },
      {
        "command": "entire.browseCheckpoints",
        "title": "Browse Checkpoints",
        "category": "Entire"
      },
      {
        "command": "entire.explainCheckpoint",
        "title": "Explain Checkpoint",
        "category": "Entire"
      },
      {
        "command": "entire.explainCommit",
        "title": "Explain Commit",
        "category": "Entire"
      },
      {
        "command": "entire.openRawTranscript",
        "title": "Open Raw Transcript",
        "category": "Entire"
      },
      {
        "command": "entire.rewindInteractive",
        "title": "Rewind To Checkpoint",
        "category": "Entire"
      },
      {
        "command": "entire.resumeBranch",
        "title": "Resume Branch Session",
        "category": "Entire"
      },
      {
        "command": "entire.runDoctor",
        "title": "Run Doctor",
        "category": "Entire"
      },
      {
        "command": "entire.clean",
        "title": "Clean Entire State",
        "category": "Entire"
      },
      {
        "command": "entire.reset",
        "title": "Reset Entire Session Data",
        "category": "Entire"
      },
      {
        "command": "entire.showTrace",
        "title": "Show Trace",
        "category": "Entire"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "entire.refresh",
          "when": "view =~ /^entire\\./",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}